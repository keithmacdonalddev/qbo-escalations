{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(node scripts/migrateNotesProcessed.js:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(git restore:*)",
      "Bash(npm test)",
      "Bash(timeout 5 node:*)",
      "Bash(node -e:*)",
      "Bash(node scripts/migrateUserRoles.js:*)",
      "Bash(xargs:*)",
      "Bash(node --check:*)",
      "Bash(tasklist:*)",
      "Bash(npm run dev:*)",
      "Bash(netstat:*)",
      "Bash(curl:*)",
      "WebFetch(domain:loggingsucks.com)",
      "Bash(node scripts/migrateDefaultCategories.js:*)",
      "Bash(node scripts/migrateDefaultTags.js:*)",
      "Bash(node scripts/seedRoleConfigs.js:*)",
      "Bash(grep:*)",
      "mcp__ide__getDiagnostics",
      "Bash(cd:*)",
      "Bash(git checkout:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || cd \"$(git rev-parse --show-toplevel)\" 2>/dev/null; bash .claude/hooks/pm-rules.sh",
            "timeout": 5,
            "statusMessage": "PM rules loaded ✓"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || cd \"$(git rev-parse --show-toplevel)\" 2>/dev/null; node .claude/hooks/config-freshness.mjs",
            "timeout": 10,
            "statusMessage": "Checking config freshness..."
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory",
  "spinnerTipsEnabled": false
}

{
  "name": "qbo-escalations",
  "version": "1.0.0",
  "private": true,
  "description": "QBO Escalation Assistant — Claude-powered tool for QBO escalation specialists",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm --prefix client run build",
    "start": "node --max-old-space-size=512 server/src/index.js",
    "test": "npm run test:server && npm run test:client && npm run test:stress-harness",
    "test:server": "npm --prefix server test",
    "test:client": "npm --prefix client test",
    "test:stress-harness": "node --test stress-testing/scripts/test/*.test.js",
    "test:ui-density": "node stress-testing/scripts/ui-density-canary.js",
    "test:client-bundle": "npm --prefix client run build && node stress-testing/scripts/client-bundle-canary.js",
    "test:image-parser": "node --test server/test/image-parser*.test.js",
    "auth:hash-password": "node server/scripts/hash-auth-password.js",
    "stress:slices": "node stress-testing/scripts/run-slices.js",
    "verify:core": "node scripts/run-app-checks.js core",
    "verify:qbo": "node scripts/run-app-checks.js focused-qbo",
    "verify:full": "node scripts/run-app-checks.js full",
    "validate:testing-map": "node scripts/validate-testing-map.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}

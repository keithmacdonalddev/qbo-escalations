    {
      "_id": "6a0f85b0ce91242b6f175fb4",
      "schemaVersion": "0.1",
      "captureVersion": "provider-harness-llm-gateway-v0.1",
      "providerId": "llm-gateway",
      "providerResearchId": "llm-gateway",
      "providerPathType": "gateway-http",
      "callSite": "image-parser:callLlmGateway",
      "operation": "image-parse",
      "source": {
        "file": "server/src/services/image-parser.js",
        "functionName": "callLlmGateway",
        "helperName": "jsonRequest",
        "spawnSite": ""
      },
      "request": null,
      "response": null,
      "cli": null,
      "lmStudio": null,
      "llmGateway": {
        "request": {
          "method": "POST",
          "baseUrl": "http://127.0.0.1:4100",
          "url": "http://127.0.0.1:4100/v1/chat/completions",
          "protocol": "http:",
          "hostname": "127.0.0.1",
          "port": 4100,
          "path": "/v1/chat/completions",
          "urlPath": "/v1/chat/completions",
          "headers": {
            "Content-Type": "application/json",
            "Accept": "application/json",
            "Authorization": "Bearer [REDACTED]",
            "Content-Length": 1426
          },
          "redactedHeaderNames": [
            "authorization"
          ],
          "bodyKind": "json",
          "bodyText": "{\"model\":\"auto\",\"max_tokens\":4096,\"temperature\":0.1,\"messages\":[{\"role\":\"system\",\"content\":\"You are the Image Parser for the QBO escalation workflow.\\n\\r\\nYour job is narrow: read one screenshot of the known escalation template and output the canonical template text only.\\r\\n\\r\\nOutput exactly these labels, in this order:\\r\\n\\r\\nCOID/MID:\\r\\nCASE:\\r\\nCLIENT/CONTACT:\\r\\nCX IS ATTEMPTING TO:\\r\\nEXPECTED OUTCOME:\\r\\nACTUAL OUTCOME:\\r\\nKB/TOOLS USED:\\r\\nTRIED TEST ACCOUNT:\\r\\nTS STEPS:\\r\\n\\r\\nRules:\\r\\n- Output no commentary, no markdown, no bullets, and no extra headings.\\r\\n- Read every visible value exactly as written.\\r\\n- Preserve spelling, capitalization, punctuation, identifiers, and line breaks.\\r\\n- If a value is missing, hidden, blank, or unreadable, leave the value blank after the label.\\r\\n- Do not include AGENT, CATEGORY, SEVERITY, OPERATOR NOTE, or any other non-canonical field.\\r\\n- Do not diagnose, summarize, rewrite, or infer what the customer means.\\r\\n- If COID and MID are both visible, include both in COID/MID separated by a slash.\\r\\n- TS STEPS may be multi-line and should preserve visible line breaks.\\r\\n\"},{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":\"Parse this image.\"},{\"type\":\"image_url\",\"image_url\":{\"url\":\"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==\"}}]}],\"chat_template_kwargs\":{\"enable_thinking\":false}}",
          "bodyTextPayloadRef": null,
          "bodyJson": {
            "model": "auto",
            "max_tokens": 4096,
            "temperature": 0.1,
            "messages": [
              {
                "role": "system",
                "content": "You are the Image Parser for the QBO escalation workflow.\n\r\nYour job is narrow: read one screenshot of the known escalation template and output the canonical template text only.\r\n\r\nOutput exactly these labels, in this order:\r\n\r\nCOID/MID:\r\nCASE:\r\nCLIENT/CONTACT:\r\nCX IS ATTEMPTING TO:\r\nEXPECTED OUTCOME:\r\nACTUAL OUTCOME:\r\nKB/TOOLS USED:\r\nTRIED TEST ACCOUNT:\r\nTS STEPS:\r\n\r\nRules:\r\n- Output no commentary, no markdown, no bullets, and no extra headings.\r\n- Read every visible value exactly as written.\r\n- Preserve spelling, capitalization, punctuation, identifiers, and line breaks.\r\n- If a value is missing, hidden, blank, or unreadable, leave the value blank after the label.\r\n- Do not include AGENT, CATEGORY, SEVERITY, OPERATOR NOTE, or any other non-canonical field.\r\n- Do not diagnose, summarize, rewrite, or infer what the customer means.\r\n- If COID and MID are both visible, include both in COID/MID separated by a slash.\r\n- TS STEPS may be multi-line and should preserve visible line breaks.\r\n"
              },
              {
                "role": "user",
                "content": [
                  {
                    "type": "text",
                    "text": "Parse this image."
                  },
                  {
                    "type": "image_url",
                    "image_url": {
                      "url": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
                    }
                  }
                ]
              }
            ],
            "chat_template_kwargs": {
              "enable_thinking": false
            }
          },

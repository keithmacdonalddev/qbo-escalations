            "Content-Length": 130319
          },
          "redactedHeaderNames": [],
          "bodyKind": "json",
          "bodyText": "{\"model\":\"google/gemma-4-e4b\",\"messages\":[{\"role\":\"system\",\"content\":\"You are the Image Parser for the QBO escalation workflow.\\n\\r\\nYour job is narrow: read one screenshot of the known escalation template and output the canonical template text only.\\r\\n\\r\\nOutput exactly these labels, in this order:\\r\\n\\r\\nCOID/MID:\\r\\nCASE:\\r\\nCLIENT/CONTACT:\\r\\nCX IS ATTEMPTING TO:\\r\\nEXPECTED OUTCOME:\\r\\nACTUAL OUTCOME:\\r\\nKB/TOOLS USED:\\r\\nTRIED TEST ACCOUNT:\\r\\nTS STEPS:\\r\\n\\r\\nRules:\\r\\n- Output no commentary, no markdown, no bullets, and no extra headings.\\r\\n- Read every visible value exactly as written.\\r\\n- Preserve spelling, capitalization, punctuation, identifiers, and line breaks.\\r\\n- If a value is missing, hidden, blank, or unreadable, leave the value blank after the label.\\r\\n- Do not include AGENT, CATEGORY, SEVERITY, OPERATOR NOTE, or any other non-canonical field.\\r\\n- Do not diagnose, summarize, rewrite, or infer what the customer means.\\r\\n- If COID and MID are both visible, include both in COID/MID separated by a slash.\\r\\n- TS STEPS may be multi-line and should preserve visible line breaks.\\r\\n\"},{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":\"Parse this image.\"},{\"type\":\"image_url\",\"image_url\":{\"url\":\"data:image/png;base64,\"}}]}],\"stream\":false,\"temperature\":0.1,\"max_tokens\":4096,\"chat_template_kwargs\":{\"enable_thinking\":false}}",
          "bodyTextPayloadRef": null,
          "bodyJson": {
            "model": "google/gemma-4-e4b",
            "messages": [
              {
                "role": "system",
                "content": "You are the Image Parser for the QBO escalation workflow.\n\r\nYour job is narrow: read one screenshot of the known escalation template and output the canonical template text only.\r\n\r\nOutput exactly these labels, in this order:\r\n\r\nCOID/MID:\r\nCASE:\r\nCLIENT/CONTACT:\r\nCX IS ATTEMPTING TO:\r\nEXPECTED OUTCOME:\r\nACTUAL OUTCOME:\r\nKB/TOOLS USED:\r\nTRIED TEST ACCOUNT:\r\nTS STEPS:\r\n\r\nRules:\r\n- Output no commentary, no markdown, no bullets, and no extra headings.\r\n- Read every visible value exactly as written.\r\n- Preserve spelling, capitalization, punctuation, identifiers, and line breaks.\r\n- If a value is missing, hidden, blank, or unreadable, leave the value blank after the label.\r\n- Do not include AGENT, CATEGORY, SEVERITY, OPERATOR NOTE, or any other non-canonical field.\r\n- Do not diagnose, summarize, rewrite, or infer what the customer means.\r\n- If COID and MID are both visible, include both in COID/MID separated by a slash.\r\n- TS STEPS may be multi-line and should preserve visible line breaks.\r\n"
              },
              {
                "role": "user",
                "content": [
                  {
                    "type": "text",
                    "text": "Parse this image."
                  },
                  {
                    "type": "image_url",
                    "image_url": {
                      "url": "data:image/png;base64,"
                    }
                  }
                ]
              }
            ],
            "stream": false,
            "temperature": 0.1,
            "max_tokens": 4096,
            "chat_template_kwargs": {
              "enable_thinking": false
            }
          },
          "bodyJsonPayloadRef": null,
          "bodyByteLength": 130319,
          "bodySha256": "dd1dde18c2b95a33b40f16e60132821bc22659ef7005375c6ca50709c276012d",

HOST=127.0.0.1
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/qbo-escalations?retryWrites=true&w=majority
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
ENABLE_DEV_MODE=true
DEV_CHAT_MAX_TIMEOUT_MS=1800000
# Workspace agent timeout — default is 600000 (10 minutes), capped in code at 1800000 (30 minutes)
# WORKSPACE_CHAT_TIMEOUT_MS=600000
# SSE safety timeout — force-closes hung chat streams (default: 300000 = 5 min)
# SSE_SAFETY_TIMEOUT_MS=300000
# Optional: leave empty to allow only loopback browser origins like http://localhost:5174
# CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Knowledgebase governance
# In production, omit KNOWLEDGE_DEFAULT_ROLE or set it to viewer unless an auth layer maps users to reviewer/publisher/admin.
# KNOWLEDGE_DEFAULT_ROLE=viewer
# In production, request role headers are ignored unless this is true and a trusted proxy/auth layer strips client-supplied role headers first.
# KNOWLEDGE_TRUST_REQUEST_ROLE_HEADERS=false
# Set true in deployed environments where the database is the source of truth and local markdown playbook writes should be disabled.
# KNOWLEDGE_MARKDOWN_PUBLISH_DISABLED=true

# Gmail API (OAuth2) — required for Gmail integration
# Get credentials from Google Cloud Console > APIs & Services > Credentials
# Enable the Gmail API and create an OAuth2 client (type: Web application)
#
# OAuth Flow:
#   1. Set GMAIL_CLIENT_ID and GMAIL_CLIENT_SECRET below
#   2. Add the redirect URI to your OAuth client's "Authorized redirect URIs" in Google Cloud Console
#   3. Users connect their Gmail account through the app UI (no manual token generation needed)
#   4. Tokens are stored in MongoDB automatically — GMAIL_REFRESH_TOKEN env var is no longer needed
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:4000/api/gmail/auth/callback

# Image Parser Agent — API keys for direct API providers
# At least one must be set for the Image Parser agent to be available.
# LM Studio uses the existing LM_STUDIO_API_URL setting.
# LLM Gateway uses your custom OpenAI-compatible gateway product.
LLM_GATEWAY_API_URL=http://127.0.0.1:4100
LLM_GATEWAY_API_KEY=
# Optional: if blank in the UI, the gateway defaults to "auto"
# LLM_GATEWAY_DEFAULT_MODEL=auto

# Codex CLI provider
# Fast tier is passed explicitly to codex exec instead of relying on the local user config.
CODEX_CHAT_MODEL=gpt-5.6-sol
CODEX_REASONING_EFFORT=high
CODEX_SERVICE_TIER=fast
CODEX_CHAT_TIMEOUT_MS=180000
CODEX_PARSE_MODEL=gpt-5.6-sol
CODEX_PARSE_REASONING_EFFORT=high
CODEX_PARSE_TIMEOUT_MS=120000

# Claude CLI provider
CLAUDE_CHAT_MODEL=claude-opus-4-8
CLAUDE_CHAT_TIMEOUT_MS=180000
CLAUDE_PARSE_MODEL=claude-opus-4-8
CLAUDE_PARSE_REASONING_EFFORT=high
CLAUDE_PARSE_TIMEOUT_MS=120000
CLAUDE_TRANSCRIBE_TIMEOUT_MS=60000
CLAUDE_SUPPORTS_IMAGE_INPUT=true

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=

# Advanced deployment fallback only. The normal setup is through the Spending
# card in Settings > AI Management. These separate organization-admin keys are
# highly privileged and must never be used as normal model API keys.
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=

# Live Call Assist speech-to-text provider
ELEVENLABS_API_KEY=
# Optional: defaults shown here; keep the API key server-side only.
# ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime
# ELEVENLABS_DISABLE_LOGGING=1
# LIVE_CALL_ASSIST_MAX_SESSION_MS=7200000

# Stress / harness testing (optional)
# Provider package capture (the evidence layer) is ON by default: every provider
# call saves its full request/response as a ProviderCallPackage. Set this to
# `false` only when you deliberately want NO evidence recorded — the server
# logs a loud startup warning when capture is disabled. Any value other than
# `false` (including unset) leaves capture enabled.
# ENABLE_PROVIDER_CALL_PACKAGE_CAPTURE=false
# STRESS_MONGODB_URI=mongodb://127.0.0.1:27017/qbo-stress
# STRESS_MONGODB_UNSAFE_ALLOW=0
# DISABLE_PROVIDER_WARMUP=1
# DISABLE_WORKSPACE_SCHEDULER=1
# DISABLE_KB_AGENT_SCHEDULER=1
# DISABLE_AI_MANAGEMENT_SCHEDULER=1
# DISABLE_WORKSPACE_MONITOR=1
# DISABLE_AGENT_HEALTHCHECK=1
# DISABLE_IMAGE_PARSER_STARTUP_CHECK=1
# DISABLE_IMAGE_PARSER_HEALTHCHECK=1
# DISABLE_IMAGE_PARSER_KEYS_MIGRATION=1
# DISABLE_RUNTIME_PRUNING=1
# RATE_LIMIT_DISABLED=1
# HARNESS_PROVIDERS_STUBBED=1
# HARNESS_PROVIDERS_NO_DEFAULT_STUBS=1
# HARNESS_CONNECTED_SERVICES_STUBBED=1
# HARNESS_CONNECTED_SERVICES_NO_DEFAULT_STUBS=1

# Signed-in QBO reporting identity (optional; required for user reporting)
# Preferred: reuse the Ticket Snitch account. QBO receives a one-time,
# project-bound reporter identity; it never receives the Ticket Snitch password,
# owner role, session cookie, or project credential.
# QBO_AUTH_MODE=ticket-snitch
# TICKET_SNITCH_WEB_URL=http://localhost:5176
# QBO_AUTH_TICKET_SNITCH_CALLBACK_URL=http://localhost:4000/api/auth/ticket-snitch/callback
# QBO_AUTH_SESSION_TTL_MS=43200000
# Exact Vite/deployed origins allowed to sign in or sign out.
# QBO_AUTH_ALLOWED_ORIGINS=http://localhost:5174
# Defaults to secure cookies in production. Set 0 only for approved local HTTP.
# QBO_AUTH_COOKIE_SECURE=0
# Standalone local fallback only: set QBO_AUTH_MODE=password, then configure
# QBO_AUTH_USER_ID, QBO_AUTH_USER_NAME, optional QBO_AUTH_USER_EMAIL, and a
# QBO_AUTH_PASSWORD_HASH generated with npm run auth:hash-password.

# Ticket Snitch cross-project tracking (optional; required for user reporting)
# Keep each project-scoped key server-side. The report key stays create-only;
# screenshot forwarding and Codex casework use separate least-privileged actors.
# TICKET_SNITCH_API_URL=http://127.0.0.1:4300/api/v1
# work-items:create only
# TICKET_SNITCH_API_KEY=ts_<key-id>.<secret>
# evidence:create only, attributed to the QBO evidence forwarding system
# TICKET_SNITCH_EVIDENCE_API_KEY=ts_<key-id>.<secret>
# work-items:read, comments:create, evidence:create, transitions:create,
# proposals:create (legacy local credentials with work-items:update remain compatible)
# TICKET_SNITCH_AGENT_API_KEY=ts_<key-id>.<secret>
# TICKET_SNITCH_PROJECT_ID=<Ticket Snitch project UUID>
# TICKET_SNITCH_TIMEOUT_MS=8000
# Exact browser origins allowed to open and submit the reporting form. Separate
# multiple origins with commas. Same-origin production requests are also allowed.
# TICKET_SNITCH_REPORT_ALLOWED_ORIGINS=http://localhost:5174
# Optional internal automation proxy. Keep this server-side and use at least 32
# random characters. This does not protect or enable the browser reporting form.
# Leave unset to disable status, agent report, read, update, comment, transition,
# and evidence routes used by trusted server-to-server automation.
# TICKET_SNITCH_REPORT_PROXY_SECRET=<random-server-to-server-secret>

# Data retention (MongoDB TTL, in days) — collections auto-prune via a TTL
# index on each doc's expiresAt. All optional; generous defaults shown.
# Retention is applied at write time, so changing a value only affects new
# documents. Lower a value to reclaim space sooner; raise it to keep history.
# USAGE_LOG_TTL_DAYS=365              # per-request usage/cost log
# IMAGE_PARSE_RESULT_TTL_DAYS=90     # image parse operational history
# IMAGE_PARSER_TEST_RESULT_TTL_DAYS=30   # disposable image-parser test runs
# TRIAGE_RESULT_TTL_DAYS=30          # standalone triage harness operational history
# TRIAGE_TEST_RESULT_TTL_DAYS=30     # disposable triage-agent test runs
# TRIAGE_PROVIDER_PACKAGE_WAIT_MS=30000  # max Mongo readback wait for captured triage provider package
# PROVIDER_CALL_PACKAGE_TTL_DAYS=30  # forensic provider request/response packages
#   NOTE: PROVIDER_CALL_PACKAGE_TTL_DAYS prunes the Mongo document only; the
#   externalized on-disk payloads under server/data/provider-call-packages/
#   are NOT removed by this TTL (on-disk cleanup is a separate backlog item).
# PROVIDER_PACKAGE_PROBE_TTL_HOURS=24  # short retention (hours, not days) for
#   provider HEALTH-PROBE packages only (operation 'provider-status': background
#   health monitor + preflight reachability checks). Probes are still captured
#   but self-clean quickly; real evidence keeps PROVIDER_CALL_PACKAGE_TTL_DAYS.

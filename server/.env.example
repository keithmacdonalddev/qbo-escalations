HOST=127.0.0.1
PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/qbo-escalations?retryWrites=true&w=majority
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
ENABLE_DEV_MODE=true
DEV_CHAT_MAX_TIMEOUT_MS=1800000
# Workspace agent timeout — default is 600000 (10 minutes), capped in code at 1800000 (30 minutes)
# WORKSPACE_CHAT_TIMEOUT_MS=600000
# SSE safety timeout — force-closes hung chat streams (default: 300000 = 5 min)
# SSE_SAFETY_TIMEOUT_MS=300000
# Optional: leave empty to allow only loopback browser origins like http://localhost:5174
# CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Gmail API (OAuth2) — required for Gmail integration
# Get credentials from Google Cloud Console > APIs & Services > Credentials
# Enable the Gmail API and create an OAuth2 client (type: Web application)
#
# OAuth Flow:
#   1. Set GMAIL_CLIENT_ID and GMAIL_CLIENT_SECRET below
#   2. Add the redirect URI to your OAuth client's "Authorized redirect URIs" in Google Cloud Console
#   3. Users connect their Gmail account through the app UI (no manual token generation needed)
#   4. Tokens are stored in MongoDB automatically — GMAIL_REFRESH_TOKEN env var is no longer needed
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:4000/api/gmail/auth/callback

# Image Parser Agent — API keys for direct API providers
# At least one must be set for the Image Parser agent to be available.
# LM Studio uses the existing LM_STUDIO_API_URL setting.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=
